{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://persona-capsule.dev/schemas/claim.schema.json",
  "title": "Persona Capsule Claim",
  "type": "object",
  "required": ["id", "type", "text", "confidence", "source_ids", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^claim_[a-zA-Z0-9_-]+$"
    },
    "type": {
      "type": "string",
      "enum": ["fact", "preference", "value", "style", "relationship", "boundary", "inference"]
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "enum": ["verified", "corroborated", "inferred", "stylistic", "unknown"]
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id"],
        "properties": {
          "source_id": {
            "type": "string"
          },
          "quote": {
            "type": "string"
          },
          "location": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
