{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://persona-capsule.dev/schemas/capsule.schema.json",
  "title": "Persona Capsule Manifest",
  "type": "object",
  "required": ["id", "version", "subject", "mode", "consent", "export_targets"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "version": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "required": ["display_name"],
      "properties": {
        "display_name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "mode": {
      "type": "string",
      "enum": ["self-continuity", "memorial", "public-figure", "fictional"]
    },
    "consent": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["self-authorized", "authorized-by-estate", "public-sources-only", "fictional", "unknown"]
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "export_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["hermes", "openclaw", "openhands", "codex", "claude-code"]
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": true
}
