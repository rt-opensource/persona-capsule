{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://persona-capsule.dev/schemas/source-index.schema.json",
  "title": "Persona Capsule Source Index",
  "type": "object",
  "required": ["sources"],
  "properties": {
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "type",
          "bytes",
          "hash",
          "sensitivity",
          "owner",
          "imported_at",
          "modified_at",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^src_[a-f0-9]{12,64}$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["markdown", "text", "json", "jsonl", "csv", "html", "pdf", "docx", "subtitle", "unknown"]
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "sensitivity": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "imported_at": {
            "type": "string",
            "format": "date-time"
          },
          "modified_at": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": ["indexed", "excluded", "review-required"]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
